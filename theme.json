      "fontWeight": "400",
      "lineHeight": "1.6",
      "letterSpacing": "0"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--spectral)",
          "fontWeight": "300",
          "lineHeight": "1.1",
          "letterSpacing": "-0.03em"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--super-hero)",
          "fontWeight": "300",
          "letterSpacing": "-0.03em"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--gigantic)",
          "fontWeight": "300",
          "letterSpacing": "-0.02em"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--huge)",
          "fontWeight": "400",
          "fontFamily": "var(--wp--preset--font-family--manrope)"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--extra-large)",
          "fontWeight": "500",
          "fontFamily": "var(--wp--preset--font-family--manrope)"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "600",
          "fontFamily": "var(--wp--preset--font-family--manrope)"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "fontWeight": "700",
          "fontFamily": "var(--wp--preset--font-family--manrope)",
          "letterSpacing": "0.02em"
        }
      },
      "code": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      }
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--medium)",
      "padding": {
        "top": "var(--wp--preset--spacing--large)",
        "bottom": "var(--wp--preset--spacing--large)"
      }
    }
